# base-image credentials — copy to `.env` (gitignored) and fill in.
# NEVER put real keys in this file: .env.example is committed.
#
# The repo-root `.env` is the canonical location; `imagegen qa` and
# tools/template_manager (create.py / test_template.py) both read it.

# Dedicated QA Vast.ai account API key (the "Template Team" account, id 525202) — NOT a
# personal account key. Required for: `imagegen qa` (rents the live-GPU test box) and
# create.py / test_template.py (template publish + test).
VAST_API_KEY=

# DockerHub STAGING namespace — the repo part `imagegen qa` builds the staging image ref
# from when `--tag` is a bare tag or omitted (i.e. <namespace>/<image>). Not needed if you
# always pass a full `--tag <repo/name:tag>`.
DOCKERHUB_NAMESPACE_STAGING=

# Optional — HuggingFace token, only if the image pulls GATED model weights during the QA
# smoke (e.g. a gated TTS/LLM checkpoint). Leave unset otherwise.
# HF_TOKEN=
