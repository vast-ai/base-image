#!/bin/bash

# Prefer sys-venv jupyter (converted images), fall back to /usr/local/bin
if [[ -x /opt/sys-venv/bin/jupyter ]]; then
    JUPYTER_BIN=/opt/sys-venv/bin/jupyter
else
    JUPYTER_BIN=/usr/local/bin/jupyter
fi

type="$1"

# Bail out if this is not a launch command
if [[ $type != "notebook" ]] && [[ $type != "lab" ]]; then
        exec "$JUPYTER_BIN" "$@"
fi

shift

# Add some useful options to the default Jupyter startup
set -- "$type" \
  "--no-browser" \
  "--ContentsManager.allow_hidden=True" \
  "--ServerApp.root_dir=/" \
  "--ServerApp.preferred_dir=${JUPYTER_DIR:-${WORKSPACE:-/}}" \
  "$@"

"$JUPYTER_BIN" "$@" 2>&1 | tee >(grep -v "health.ico" >> /var/log/portal/jupyter.log)
